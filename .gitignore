# Anchor the rule to the repo root — the real lockfile lives at
# src/ResQ.Viz.Web/package-lock.json and must be tracked for `npm ci`
# in CI and Dependabot to work. An un-anchored `package-lock.json`
# ignore would mask both. A root-level one, if present, is the
# artefact of running `npm install` from the wrong CWD; keep ignoring.
/package-lock.json

# Vite build outputs (generated from client/)
src/ResQ.Viz.Web/wwwroot/

# npm
src/ResQ.Viz.Web/node_modules/
src/ResQ.Viz.Web/client/node_modules/

# NuGet scratch/cache directories that can appear when restore/build tools run
NuGetScratch*/
dotnet-sdk-advertising-temp/

# Python
__pycache__/

# Playwright / browser automation logs
.playwright-mcp/

# Security assessment deliverables (contain internal IPs, exploitation evidence)
deliverables/

# Generated outputs
outputs/

# Local docs (specs, plans — not committed)
docs/
